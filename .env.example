# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริงจาก Supabase
# (Project Settings -> API)

# Project URL เช่น https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (ขึ้นต้นด้วย sb_publishable_...) — ปลอดภัยที่จะใช้ฝั่ง client เพราะมี RLS ป้องกัน
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────────
# Cloudflare R2 — เก็บไฟล์แนบของโน้ต (รูปภาพ/PDF)
# (Cloudflare Dashboard -> R2 -> Manage R2 API Tokens)
#
# ⚠️ เป็นความลับฝั่ง server เท่านั้น — ห้ามมี prefix NEXT_PUBLIC_
#    ห้ามใส่ค่าจริงในไฟล์นี้ (เป็นเทมเพลตสำหรับแชร์/commit) — ใส่ใน .env.local เท่านั้น
#    bucket ตั้งเป็น private; แอปสร้าง presigned URL ให้เอง
#    ถ้าไม่ตั้งครบ การอัปโหลดไฟล์จะถูกปฏิเสธพร้อมข้อความ error
# ─────────────────────────────────────────────────────────────

# Account ID ของ Cloudflare (ใช้ประกอบ endpoint <account>.r2.cloudflarestorage.com)
R2_ACCOUNT_ID=

# Access Key ID จาก R2 API Token
R2_ACCESS_KEY_ID=

# Secret Access Key จาก R2 API Token
R2_SECRET_ACCESS_KEY=

# ชื่อ bucket ที่ใช้เก็บไฟล์แนบ
R2_BUCKET=
